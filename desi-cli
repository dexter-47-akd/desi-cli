}

update_script() {
    printf "[branch:%s] Checking for Update..\n" "$branch"
    update="$(curl --fail-with-body -sL -A "$agent" "https://raw.githubusercontent.com/dexter-47-akd/-arvndhl-desi-cli/$branch/desi-cli")" || die "[branch:$branch] Connection error: $update"
    printf '%s' "$update" | grep -q "^version_number" || die "[branch:$branch] Invalid Response."
    update="$(printf '%s\n' "$update" | diff -u "$0" -)"
    if [ -z "$update" ]; then
        printf "[branch:%s] Script is up to date\n" "$branch"
    else
        if printf '%s\n' "$update" | patch "$0" -; then
            printf "[branch:%s] Script has been updated\n" "$branch"
        else
            die "[branch:$branch] Can't update for some reason!"
        fi
    fi
    exit 0
}

dep_ch() {
    for dep; do
        command -v "${dep%% *}" >/dev/null || die "Program \"${dep%% *}\" not found. Please install it."
    done
}

open_browser() {
    url="$1"
    case "$(uname -a | cut -d " " -f 1,3-)" in
        *MINGW*|*MSYS*) cmd //c start "$url" >/dev/null 2>&1 ;;
        *Darwin*) open "$url" >/dev/null 2>&1 ;;
        *Linux*) xdg-open "$url" >/dev/null 2>&1 ;;
        *) printf "\33[2K\r\033[1;33mOpen this URL in your browser:\033[0m\n%s\n" "$url" >&2 ;;
    esac
}

