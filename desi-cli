# Build search query with language context
build_search_query() {
    raw_query="$1"
    lang="$2"
    content_type="$3"

    case "$lang" in
        all) lang_suffix="" ;;
        hindi) lang_suffix="hindi" ;;
        marathi) lang_suffix="marathi" ;;
        tamil) lang_suffix="tamil" ;;
        telugu) lang_suffix="telugu" ;;
        malayalam) lang_suffix="malayalam" ;;
        kannada) lang_suffix="kannada" ;;
        bengali) lang_suffix="bengali" ;;
        punjabi) lang_suffix="punjabi" ;;
        *) lang_suffix="$lang" ;;
    esac

    if [ -n "$lang_suffix" ]; then
        query_full="${raw_query} ${lang_suffix}"
    else
        query_full="${raw_query}"
    fi

    if [ "$content_type" = "movie" ]; then
        query_full="${query_full} movie"
    fi

    printf "%s" "$query_full" | sed 's/^ *//;s/ *$//'
}

# ===== YOUTUBE PROVIDER =====

search_youtube() {
    search_query="$1"
    search_url="ytsearch15:${search_query}"

    if [ "$debug" = 1 ]; then
        printf "\33[2K\r\033[1;33m[YouTube] Searching: %s\033[0m\n" "$search_query" >&2
    fi

    yt_output=$(yt-dlp "$search_url" --flat-playlist --print "$(printf '%s\t%s\t%s\t%s' '%(title)s' '%(id)s' '%(channel)s' '%(duration)s')" 2>/dev/null)

    if [ -z "$yt_output" ]; then
        return 1
    fi

    index=1
    printf "%s" "$yt_output" | while IFS='	' read -r title id channel duration_float; do
        [ -z "$title" ] && continue
        url="https://www.youtube.com/watch?v=${id}"

        duration_str=""
        if [ -n "$duration_float" ] && [ "$duration_float" != "null" ] && [ "$duration_float" != "None" ]; then
            duration_int=$(printf "%s" "$duration_float" | sed 's/\.[0-9]*//')
            [ -z "$duration_int" ] && duration_int=0
            mins=$((duration_int / 60)) 2>/dev/null
            secs=$((duration_int % 60)) 2>/dev/null
            duration_str="${mins}m${secs}s"
        fi

        label="${title}"
        [ -n "$duration_str" ] && label="${label} [${duration_str}]"
        [ -n "$channel" ] && label="${label} | ${channel}"

        printf "%s\t%s\t%s\n" "$index" "$url" "$label"
        index=$((index + 1))
    done
}

get_youtube_video_url() {
    video_url="$1"
    quality="$2"

    [ "$debug" = 1 ] && printf "\33[2K\r\033[1;33m[YouTube] Extracting video URL: %s\033[0m\n" "$video_url" >&2

    case "$quality" in
        best)   format="best[acodec!=?none]/best" ;;
        worst)  format="worst[acodec!=?none]/worst" ;;
        *p|*P)  h=$(printf "%s" "$quality" | sed 's/[pP]//')
                format="best[height<=${h}][acodec!=?none]/best[height<=${h}]" ;;
        0)      format="best[acodec!=?none]/best" ;;
        *)      format="best[acodec!=?none]/best" ;;
    esac

    [ "$debug" = 1 ] && printf "\33[2K\r\033[1;33m[YouTube] Format: %s\033[0m\n" "$format" >&2

    # Detect JS runtime (deno) and add to PATH
    for deno_bin in "$HOME/.deno/bin" "$HOME/AppData/Roaming/npm/node_modules/deno" "$LOCALAPPDATA/npm/node_modules/deno"; do
        if [ -f "$deno_bin/deno.exe" ] || [ -f "$deno_bin/deno" ]; then
            PATH="$deno_bin:$PATH"
            break
        fi
    done

    js_args=""
    remote_components=""
    if command -v deno >/dev/null 2>&1; then
        js_args="--js-runtimes deno"
        remote_components="--remote-components ejs:github"
        [ "$debug" = 1 ] && printf "\33[2K\r\033[1;33m[YouTube] Using JS runtime: deno\033[0m\n" >&2
    fi

    stream_url=""

    # Attempt 1: with cookies file (if provided)
    if [ -z "$stream_url" ] && [ -n "$cookies_file" ] && [ -f "$cookies_file" ]; then
        stream_url=$(yt-dlp -f "$format" -g "$video_url" --cookies "$cookies_file" --socket-timeout 15 $js_args $remote_components 2>/dev/null)
    fi

    # Attempt 2: with cookies from browser
    if [ -z "$stream_url" ]; then
        for browser in chrome edge firefox brave opera; do
            stream_url=$(yt-dlp -f "$format" -g "$video_url" --cookies-from-browser "$browser" --socket-timeout 15 $js_args $remote_components 2>/dev/null)
            [ -n "$stream_url" ] && break
        done
    fi

    # Attempt 3: normal extraction
    if [ -z "$stream_url" ]; then
        stream_url=$(yt-dlp -f "$format" -g "$video_url" --socket-timeout 15 $js_args $remote_components 2>/dev/null)
    fi

    # Attempt 4: android client
    if [ -z "$stream_url" ]; then
        stream_url=$(yt-dlp -f "$format" -g "$video_url" --extractor-args "youtube:player_client=android" --socket-timeout 15 $js_args $remote_components 2>/dev/null)
    fi

    # Attempt 5: worst quality
    if [ -z "$stream_url" ]; then
        stream_url=$(yt-dlp -f "worst" -g "$video_url" --socket-timeout 15 $js_args $remote_components 2>/dev/null)
    fi

    # Attempt 6: any format
    if [ -z "$stream_url" ]; then
        stream_url=$(yt-dlp -g "$video_url" --socket-timeout 20 $js_args $remote_components 2>/dev/null)
    fi

    if [ -z "$stream_url" ]; then
        printf "\33[2K\r\033[1;33mYouTube extraction failed. The video may require sign-in.\033[0m\n" >&2
        printf "\33[2K\r\033[1;33mTry:  yt-dlp --cookies-from-browser chrome \"$video_url\"\033[0m\n" >&2
        printf "\33[2K\r\033[1;33mOr export cookies (Get cookies.txt extension) and use --cookies-file\033[0m\n" >&2
    fi

    printf "%s" "$stream_url"
}

get_youtube_title() {
    video_url="$1"
    yt-dlp --print title "$video_url" 2>/dev/null
}

# ===== ZEE5 PROVIDER =====

search_zee5() {
    search_query="$1"
    encoded_query=$(printf "%s" "$search_query" | sed 's/ /+/g')

    [ "$debug" = 1 ] && printf "\33[2K\r\033[1;33m[ZEE5] Searching via Mojeek: %s\033[0m\n" "$search_query" >&2

    search_html=$(curl -sL -A "$agent" "https://www.mojeek.com/search?q=site:zee5.com+${encoded_query}" 2>/dev/null)

    [ -z "$search_html" ] && return 1

    index=1

    printf "%s\n" "$search_html" | while IFS= read -r line; do
        case "$line" in
            *'class="title"'*)
                url=$(printf "%s" "$line" | sed 's/.*href="\([^"]*\)".*/\1/')
                title=$(printf "%s" "$line" | sed 's/.*class="title"[^>]*>\([^<]*\)<.*/\1/')
                [ "$url" = "$line" ] && continue
                [ "$title" = "$line" ] && continue
                case "$url" in
                    *zee5.com/movies/details/*|*zee5.com/shows/details/*|*zee5.com/global/videos/details/*)
                        printf "%s\t%s\t%s\n" "$index" "$url" "$title"
                        index=$((index + 1))
                        ;;
                esac
                ;;
        esac
    done
}

# ===== EINTHUSAN PROVIDER =====

get_einthusan_video_url() {
    movie_url="$1"
    quality="$2"

    if [ "$debug" = 1 ]; then
        printf "\33[2K\r\033[1;33m[Einthusan] Extracting video URL: %s\033[0m\n" "$movie_url" >&2
    fi

    case "$quality" in
        best)
            stream_url=$(yt-dlp -f "bestvideo+bestaudio/best" -g "$movie_url" 2>/dev/null)
            ;;
        worst)
            stream_url=$(yt-dlp -f "worstvideo+worstaudio/worst" -g "$movie_url" 2>/dev/null)
            ;;
        *p | *P)
            height=$(printf "%s" "$quality" | sed 's/[pP]//')
            stream_url=$(yt-dlp -f "bestvideo[height<=${height}]+bestaudio/best[height<=${height}]" -g "$movie_url" 2>/dev/null)
            ;;
        0)
            stream_url=$(yt-dlp -f "bestvideo+bestaudio/best" -g "$movie_url" 2>/dev/null)
            ;;
        *)
            stream_url=$(yt-dlp -f "best" -g "$movie_url" 2>/dev/null)
            ;;
    esac

    if [ -z "$stream_url" ]; then
        stream_url=$(yt-dlp -g "$movie_url" 2>/dev/null)
    fi

    printf "%s" "$stream_url"
}

# ===== MX PLAYER PROVIDER (URL only - search unavailable, geo-blocked) =====

get_mxplayer_video_url() {
    video_url="$1"
    quality="$2"

    [ "$debug" = 1 ] && printf "\33[2K\r\033[1;33m[MX Player] Extracting video URL: %s\033[0m\n" "$video_url" >&2

    stream_url=""

    # Extract video ID (last 32-char hex segment from URL)
    video_id=$(printf "%s" "$video_url" | sed -n 's/.*\/\([a-f0-9]\{32\}\)$/\1/p' | sed 's/.*\/\([a-f0-9]\{32\}\)\?watch=true/\1/')
    [ -z "$video_id" ] && video_id=$(printf "%s" "$video_url" | grep -o '[a-f0-9]\{32\}' | tail -1)

    # Determine type: episode (show) or movie
    if printf "%s" "$video_url" | grep -q "/show/"; then
        api_type="episode"
    else
        api_type="movie"
    fi

    [ "$debug" = 1 ] && printf "\33[2K\r\033[1;33m[MX Player] ID: %s, Type: %s\033[0m\n" "$video_id" "$api_type" >&2

    if [ -n "$video_id" ]; then
        # Try direct API call (new api.mxplayer.in endpoint)
        api_response=$(curl -sL -A "$agent" \
            -H "Origin: https://www.mxplayer.in" \
            -H "Referer: https://www.mxplayer.in/" \
            "https://api.mxplayer.in/v1/web/detail/video?type=${api_type}&id=${video_id}" 2>/dev/null)

        # Extract stream path from JSON (prefer DASH, fallback to HLS)
        stream_path=$(printf "%s" "$api_response" | sed -n 's/.*"dash"[^}]*"high"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/p' | head -1)
        [ -z "$stream_path" ] && stream_path=$(printf "%s" "$api_response" | sed -n 's/.*"hls"[^}]*"high"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/p' | head -1)

        if [ -n "$stream_path" ]; then
            stream_url="https://llvod.mxplay.com/${stream_path}"

            # If quality specified, use yt-dlp on the stream URL for format selection
            if [ -n "$quality" ] && [ "$quality" != "best" ]; then
                case "$quality" in
                    worst)  qformat="worst" ;;
                    *p|*P)  qformat="bestvideo[height<=$(printf "%s" "$quality" | sed 's/[pP]//')]+bestaudio/best" ;;
                    *)      qformat="" ;;
                esac
                if [ -n "$qformat" ]; then
                    filtered=$(yt-dlp -f "$qformat" -g "$stream_url" --socket-timeout 15 2>/dev/null)
                    [ -n "$filtered" ] && stream_url="$filtered"
                fi
            fi
        fi
    fi

    if [ -z "$stream_url" ]; then
        printf "\33[2K\r\033[1;33m[MX Player] Could not extract video URL. The content may require login or be unavailable.\033[0m\n" >&2
    fi

    printf "%s" "$stream_url"
}

